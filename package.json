{
  "name": "sellit-monorepo",
  "version": "1.0.0",
  "description": "Unified SellIt Campus Marketplace",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm start -w server",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.24"
  }
}
